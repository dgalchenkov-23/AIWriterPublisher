{
  "60": {
    "class_type": "LoadImage",
    "inputs": { "image": "draft.png" }
  },
  "77": {
    "class_type": "GroundingDinoModelLoader (segment anything)",
    "inputs": { "model_name": "GroundingDINO_SwinT_OGC (694MB)" }
  },
  "78": {
    "class_type": "SAMModelLoader (segment anything)",
    "inputs": { 
        "model_name": "sam_vit_b (375MB)", 
        "device_mode": "cpu" 
    }
  },
  "79": {
    "class_type": "GroundingDinoSAMSegment (segment anything)",
    "inputs": {
      "prompt": "object to remove",
      "threshold": 0.3,
      "sam_model": ["78", 0],
      "grounding_dino_model": ["77", 0],
      "image": ["60", 0]
    }
  },
  "72": {
    "class_type": "FeatherMask",
    "inputs": {
      "mask": ["79", 1],
      "left": 7,
      "top": 7,
      "right": 7,
      "bottom": 7
    }
  },
  "mask_to_image": {
    "class_type": "MaskToImage",
    "inputs": { "mask": ["72", 0] }
  },
  "mask_save": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "mask", "images": ["mask_to_image", 0] }
  }
}